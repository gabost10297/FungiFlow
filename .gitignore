# Databases and indices
database/*
!database/.gitkeep

# Raw sequencing data
raw_data/*
!raw_data/.gitkeep

# Intermediate and temporary files
intermediate_data/*
!intermediate_data/.gitkeep

tmp/*
!tmp/.gitkeep

# Analysis results (generated by scripts)
blast_results/*
!blast_results/.gitkeep

kraken_results/*
!kraken_results/.gitkeep

consensus_results/*
!consensus_results/.gitkeep

# Python cache and system junk
__pycache__/
*.py[cod]
*$py.class
.DS_Store
Thumbs.db

# Other local files
.env
.wslconfig